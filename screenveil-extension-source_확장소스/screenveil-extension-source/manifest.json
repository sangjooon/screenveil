{
  "manifest_version": 3,
  "name": "Screen Veil",
  "description": "Blur selected work, media, and AI tabs when you step away, with instant custom-site protection and adjustable privacy strength.",
  "version": "0.4.0",
  "permissions": [
    "idle",
    "storage",
    "scripting",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Screen Veil",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "commands": {
    "quick-lock-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+9",
        "mac": "Command+Shift+9"
      },
      "description": "Blur the current tab immediately"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
